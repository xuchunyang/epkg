<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{name}} - Emacs Packages</title>
    <link href="/package.css" rel="stylesheet">
  </head>
  <body>
    <header class="site-header">
      <div class="page">
        <nav class="top-nav" aria-label="Package navigation">
          <a href="/">EPKG</a>
          <span>{{name}}</span>
        </nav>
        <div class="package-heading">
          <div>
            <p class="eyebrow">Package</p>
            <h1>{{name}}</h1>
            <p class="summary">{{summary}}</p>
          </div>
          {{#homepage}}
          <a class="homepage-link" href="{{homepage}}" rel="noreferrer">{{homepageDisplay}}</a>
          {{/homepage}}
        </div>
      </div>
    </header>

    <main class="page layout">
      <aside class="metadata" aria-label="Package metadata">
        {{#authors_rendered}}
        <div>
          <span class="meta-label">Author</span>
          <span class="meta-value">{{authors_rendered}}</span>
        </div>
        {{/authors_rendered}}

        {{#updated}}
        <div>
          <span class="meta-label">Updated</span>
          <time class="meta-value" datetime="{{updated.iso}}">{{updated.readable}}</time>
        </div>
        {{/updated}}

        <div>
          <span class="meta-label">Dependencies</span>
          <span class="meta-value">{{dependencyCount}}</span>
        </div>

        <div>
          <span class="meta-label">Used by</span>
          <span class="meta-value">{{reverseDependencyCount}}</span>
        </div>
      </aside>

      <div class="content">
        <section class="panel">
          <div class="section-heading">
            <p class="eyebrow">Documentation</p>
            <h2>Commentary</h2>
          </div>
          {{#commentary}}
          <pre>{{commentary}}</pre>
          {{/commentary}}
          {{^commentary}}
          <p class="muted">No commentary is available for this package.</p>
          {{/commentary}}
        </section>

        <section class="dependency-grid" aria-label="Package relationships">
          <div class="panel">
            <div class="section-heading">
              <p class="eyebrow">Requires</p>
              <h2>Dependencies</h2>
            </div>
            {{#hasDependencies}}
            <ul class="link-list">
              {{#required}}
              <li><a href="/{{feature}}/">{{feature}}</a></li>
              {{/required}}
            </ul>
            {{/hasDependencies}}
            {{^hasDependencies}}
            <p class="muted">No package dependencies recorded.</p>
            {{/hasDependencies}}
          </div>

          <div class="panel">
            <div class="section-heading">
              <p class="eyebrow">Consumers</p>
              <h2>Reverse Dependencies</h2>
            </div>
            {{#hasReverseDependencies}}
            <ul class="link-list">
              {{#required_by}}
              <li><a href="/{{package}}/">{{package}}</a></li>
              {{/required_by}}
            </ul>
            {{/hasReverseDependencies}}
            {{^hasReverseDependencies}}
            <p class="muted">No reverse dependencies recorded.</p>
            {{/hasReverseDependencies}}
          </div>
        </section>
      </div>
    </main>
  </body>
</html>
